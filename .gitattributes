# Normalize line endings: store text as LF in the repo, check out native on each OS.
* text=auto

# Scripts that must keep specific endings
*.sh   text eol=lf
gradlew text eol=lf
*.bat  text eol=crlf
gradlew.bat text eol=crlf

# Treat these as binary (never normalize / diff)
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.apk binary
*.keystore binary
